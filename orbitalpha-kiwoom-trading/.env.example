# =============================================================================
# SAMPLE ONLY — safe to commit. Copy to ".env" and fill real values locally.
# Never commit .env (gitignored). Real passwords / Kiwoom keys belong ONLY in .env.
#
# Live mode: real REST 잔고/시세 + optional guarded one-shot test BUY (see LIVE_* / LIVE_TEST_*).
# =============================================================================

APP_NAME=orbitalpha-kiwoom-trading
APP_ENV=development
# 운영 VM(Lightsail 등): NODE_ENV=production 권장
# NODE_ENV=production
TZ=Asia/Seoul
LOG_LEVEL=info
PAPER_TRADING=true
LOOP_INTERVAL_MS=5000
# Empty = run until Ctrl+C. Set e.g. 3 for a short smoke test.
PAPER_LOOP_MAX_TICKS=
SIGNALS_DIR=data/signals
LOGS_DIR=logs
# Optional: JSON summary output (default data/reports)
REPORTS_DIR=data/reports
TRADES_DIR=data/trades
# Paper-only dashboard (read-only HTTP server; no Kiwoom / no live orders)
# PAPER_DASHBOARD_FILE=data/paper-dashboard.json
# 절대 경로 또는 KIWOOM_PROJECT_ROOT(위)와 함께 사용해 엔진·UI 경로 일치 권장
# PAPER_DASHBOARD_PORT=3002
# HTTP 바인드 (Nginx 뒤면 127.0.0.1)
# MONITOR_HOST=127.0.0.1
# MONITOR_PORT=3001
# PAPER_DASHBOARD_HOST=127.0.0.1
# Nginx 하위 경로 배포 시 상호 이동 링크용 (예: /kiwoom → /kiwoom/live/, /kiwoom/paper/). 비우면 X-Forwarded-* 또는 로컬 포트 URL
# KIWOOM_PUBLIC_BASE_PATH=/kiwoom
SIGNAL_CANDIDATE_MIN_SCORE=38
UNIVERSE_MIN_TURNOVER_KRW=500000000
UNIVERSE_EXCLUDE_ETF_ETN=true
UNIVERSE_EXCLUDE_NON_NORMAL=true
# Optional: override session for mock paper loop (e.g. REGULAR at night). Empty = use clock.
# CLOSED | PRE_OPEN | PREMARKET | REGULAR | AFTER_HOURS
FORCE_SESSION_PHASE=
# Optional: suffix for data/signals, logs, data/reports filenames when comparing runs
EXPERIMENT_TAG=
# Mock pump paper trading (in-memory; not live orders)
PAPER_MAX_OPEN_POSITIONS=1
PAPER_ENTRY_MIN_SCORE=40
PAPER_MAX_ENTRIES_PER_TICK=2
PAPER_STOP_LOSS_PCT=1.5
PAPER_TAKE_PROFIT_PCT=3.0
PAPER_MAX_HOLD_TICKS=12
PAPER_TRAILING_STOP_PCT=1.2
PAPER_POSITION_SIZE_KRW=300000
PAPER_FILL_SLIPPAGE_PCT=0.02
# Paper 진입 시 상한가까지 남은 여유(%)가 이 값보다 작으면 제외 (국내주식 가격제한폭)
PAPER_MIN_HEADROOM_TO_UPPER_LIMIT_PCT=5.0
# 전일 종가 대비 당일 상승률(%)이 이 값을 초과하면 pump 진입 제외
PAPER_MAX_CHANGE_FROM_PREV_CLOSE_PCT=20
# 당일 고저 범위 대비 윗꼬리 비율(%)이 이 값을 초과하면 pump 진입 제외
PAPER_MAX_UPPER_WICK_RATIO_PCT=45
# US-linked mock risk regime (no API; see README)
US_FILTER_ENABLED=true
US_NASDAQ_FUTURES_NEGATIVE_PCT=-0.5
US_USDKRW_POSITIVE_PCT=0.5
US_KOSPI200_FUTURES_NEGATIVE_PCT=-0.5
US_RISK_BLOCK_MODE=true
# Block mode off 시 risk-off일 때 점수만 감점
US_RISK_SCORE_PENALTY=10
# Mock 시나리오: normal | weak | strong
US_MOCK_RISK_SCENARIO=normal
# Monday weekend-news guard (mock flags; see README)
MONDAY_FILTER_ENABLED=true
MONDAY_OPEN_BLOCK_MINUTES=10
MONDAY_EXTRA_SCORE_PENALTY=8
MONDAY_WEEKEND_RISK_BLOCK_THRESHOLD=3
MONDAY_WEEKEND_RISK_PENALTY_THRESHOLD=2
MONDAY_GAP_STRICTER_PCT=15
# Mock: normal | caution | severe
MONDAY_MOCK_WEEKEND_SCENARIO=normal
# Dev: 1=Monday, minutes after 09:00 (with FORCE_SESSION_PHASE=REGULAR for night runs)
# MONDAY_DEV_SIMULATE_WEEKDAY=1
# MONDAY_DEV_SIMULATE_MINUTES_AFTER_OPEN=5

# --- Auth & entry (local only; no DB) ---
# If AUTH_ENABLED=true: set all three passwords in .env only (non-empty). Not in this sample file.
AUTH_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=
TRADER_USERNAME=trader
TRADER_PASSWORD=
# When AUTH_ENABLED=false: viewer | trader
AUTH_BYPASS_ROLE=viewer
# paper | reports | live | menu (empty: paper if auth off, else menu)
# APP_ENTRY_MODE=live requires KIWOOM_ACCOUNT_NO + KIWOOM_API_KEY + KIWOOM_API_SECRET in .env (startup check).
# Real orders only via LIVE_TEST_* guards + submitLiveTestBuyOrderOnce (no strategy auto-orders).
# APP_ENTRY_MODE=

# --- Live: strategy auto-orders stay OFF; optional one-shot REST test buy (strict guards) ---
# Enables live guard rails (dry-run intent + test-order prerequisites). Does NOT enable strategy auto-live.
LIVE_TRADING_ENABLED=false
LIVE_CONFIRMATION_REQUIRED=true
LIVE_MAX_DAILY_LOSS_KRW=100000
LIVE_MAX_ORDER_SIZE_KRW=300000
LIVE_MAX_OPEN_POSITIONS=1
# One-shot test buy (KRX limit BUY 1 share) — all must match; otherwise order is blocked with logs.
LIVE_TEST_ORDER_ENABLED=false
LIVE_TEST_MAX_QTY=1
LIVE_TEST_MAX_ORDERS_PER_DAY=1
LIVE_TEST_ALLOWED_SYMBOL=005930
# Must be exactly EXECUTE_TEST_BUY_ONCE (literal) to arm the confirmation gate.
LIVE_TEST_ORDER_CONFIRM=
# Daily counter file (optional path relative to cwd)
# LIVE_TEST_STATE_FILE=data/live-test-order-state.json

# --- Korean cash equity paper costs (percent points: 0.015 = 0.015%) ---
KIWOOM_FEE_BUY_PCT=0.015
KIWOOM_FEE_SELL_PCT=0.015
# Sell-side transaction tax (retail simplified; 매도 시에만)
KIWOOM_TAX_SELL_PCT=0.2
# true = include tax in PnL + cost-edge filter (false = fees + slippage only)
PAPER_INCLUDE_TAX=true
# Extra margin above min round-trip cost for pump entry (percent points, e.g. 0.4 = 0.4%)
PAPER_COST_EDGE_BUFFER_PCT=0.4

# Kiwoom REST — put real values only in .env (not in .env.example).
# Required when APP_ENTRY_MODE=live (connection check). Mock host: https://mockapi.kiwoom.com
KIWOOM_MODE=paper
KIWOOM_ACCOUNT_NO=
KIWOOM_API_KEY=
KIWOOM_API_SECRET=
# OAuth: 운영 `https://api.kiwoom.com/oauth2/token` · 모의 `https://mockapi.kiwoom.com/oauth2/token` (키움 REST 포털 가이드와 동일)
# KIWOOM_REST_BASE_URL=https://api.kiwoom.com
# KIWOOM_REST_OAUTH_PATH=/oauth2/token
# KIWOOM_REST_ACNT_PATH=/api/dostk/acnt
# ka10001 등: `/api/dostk/stkinfo` ( `/api/dostk/stk` 는 ka10001 미지원 )
# KIWOOM_REST_STK_PATH=/api/dostk/stkinfo
# KIWOOM_REST_ORDR_PATH=/api/dostk/ordr
# TR api-id headers (override if your app uses different TR ids)
# KIWOOM_TR_BALANCE=kt00005
# KIWOOM_TR_QUOTE=ka10001
# KIWOOM_TR_BUY=kt10000

# --- Local read-only monitor (npm run monitor) — optional ---
# MONITOR_PORT=3001
# 스냅샷 JSON: 엔진(merge)과 monitor 서버가 같은 경로를 써야 함. PM2 cwd가 다를 수 있으면 절대 경로 권장.
# MONITOR_STATUS_FILE=data/monitor-status.json
# MONITOR_STATUS_FILE=/home/admin/.../orbitalpha-kiwoom-trading/data/monitor-status.json
# 또는 프로젝트 루트만 고정 (기본 파일 = <루트>/data/monitor-status.json)
# KIWOOM_PROJECT_ROOT=/home/admin/.../orbitalpha-kiwoom-trading
