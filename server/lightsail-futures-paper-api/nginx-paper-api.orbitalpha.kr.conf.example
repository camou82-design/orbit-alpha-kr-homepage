# Copy to /etc/nginx/sites-available/ and symlink sites-enabled.
# Replace ssl_certificate paths after: sudo certbot certonly --nginx -d paper-api.orbitalpha.kr
# DNS: A record paper-api -> Lightsail public IP

server {
    listen 80;
    server_name paper-api.orbitalpha.kr;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name paper-api.orbitalpha.kr;

    ssl_certificate     /etc/letsencrypt/live/paper-api.orbitalpha.kr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paper-api.orbitalpha.kr/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:3991;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
